# Apify Configuration
# Get your Apify token from: https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_token_here

# Apify Actor IDs
APIFY_UPWORK_ACTOR_ID=flash_mage~upwork
APIFY_FIVERR_ACTOR_ID=piotrv1001~fiverr-listings-scraper
APIFY_FREELANCER_ACTOR_ID=consummate_mandala~freelancer-project-scraper
APIFY_PEOPLEPERHOUR_ACTOR_ID=getdataforme~peopleperhour-job-scraper

# Database Configuration
# PostgreSQL connection string format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/lead_scraper

# Credit Management
FREE_PLAN_CREDIT_LIMIT=5.0
CREDIT_WARNING_THRESHOLD=80.0
CREDIT_STOP_THRESHOLD=95.0

# Database Connection Pool
DATABASE_POOL_SIZE=10

# Scraping Defaults
DEFAULT_MAX_RESULTS=100
DEFAULT_PAGE_LIMIT=50

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/lead_scraper.log
LOG_MAX_SIZE_MB=100

# Platform Authentication (Optional)
# Provide credentials to enable authenticated scraping for better access to job listings
# Leave empty to use anonymous scraping (default behavior)

# Upwork credentials
UPWORK_USERNAME=
UPWORK_PASSWORD=
UPWORK_COOKIES=

# Freelancer credentials
FREELANCER_USERNAME=
FREELANCER_PASSWORD=
FREELANCER_COOKIES=

# Fiverr credentials
FIVERR_USERNAME=
FIVERR_PASSWORD=
FIVERR_COOKIES=

# PeoplePerHour credentials
PEOPLEPERHOUR_USERNAME=
PEOPLEPERHOUR_PASSWORD=
PEOPLEPERHOUR_COOKIES=
